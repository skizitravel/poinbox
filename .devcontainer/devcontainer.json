{
  "name": "POInbox MVP",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "python -m pip install -r requirements.txt && cp -n .env.example .env.local || true",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "POInbox MVP",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
