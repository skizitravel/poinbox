APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=https://app.mountaingoat.ai

DATABASE_PATH=/data/db.sqlite
STORAGE_DIR=/data/storage
SAMPLES_DIR=/data/samples/inbox
TEST_CORPUS_DIR=/data/samples/test-corpus

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_NAME=MountainGoat Admin
INITIAL_ADMIN_PASSWORD=replace-with-a-long-first-run-password

SESSION_TTL_HOURS=168
SESSION_COOKIE_NAME=mountaingoat_session
SESSION_COOKIE_SECURE=1

# Use a long random string or a Fernet key. Keep this stable for the instance.
ENCRYPTION_KEY=replace-with-a-long-random-secret

OPENAI_MODEL=gpt-4.1-mini
USE_OPENAI_EXTRACTION=0
OCR_PROVIDER=none
ENABLE_BACKGROUND_SYNC=0

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://app.mountaingoat.ai/api/oauth/gmail/callback
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT=common
OUTLOOK_REDIRECT_URI=https://app.mountaingoat.ai/api/oauth/outlook/callback
OUTLOOK_SCOPES=offline_access User.Read Mail.Read
