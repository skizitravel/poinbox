OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000
DATABASE_PATH=data/poinbox_po.sqlite
STORAGE_DIR=storage
SAMPLES_DIR=samples/inbox
USE_OPENAI_EXTRACTION=0
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_NAME=Local Admin
INITIAL_ADMIN_PASSWORD=admin
SESSION_TTL_HOURS=168
SESSION_COOKIE_NAME=mountaingoat_session
SESSION_COOKIE_SECURE=0
ENCRYPTION_KEY=
OCR_PROVIDER=none
TEST_CORPUS_DIR=samples/test-corpus
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://127.0.0.1:8000/api/oauth/gmail/callback
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT=common
OUTLOOK_REDIRECT_URI=http://127.0.0.1:8000/api/oauth/outlook/callback
OUTLOOK_SCOPES=offline_access User.Read Mail.Read
ENABLE_BACKGROUND_SYNC=0
