# Application environment (dev | prod)
APP_ENV=dev

# SQLite database file path
DATABASE_URL=sqlite:///./po_inbox_monitor.db

# Mailbox mode: mock | graph
MAILBOX_MODE=mock

# Path to sample CSV (used in mock mode)
MOCK_CSV_PATH=data/sample_inbox_messages.csv

# --- Microsoft Graph (used in graph mode — not required for first draft) ---
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=
# GRAPH_MAILBOX_USER=
# GRAPH_FOLDER_NAME=Inbox
